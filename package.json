{
  "name": "webshop-chatgpt-mcp",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "MCP server for ChatGPT webshop order access with a Medusa OAuth broker.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect": "npx @modelcontextprotocol/inspector@latest --server-url http://localhost:8787/mcp --transport http"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.2",
    "@vercel/functions": "^2.2.13",
    "dotenv": "^16.4.7",
    "jose": "^6.0.13",
    "pino": "^9.7.0",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
