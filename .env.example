PORT=8787
MCP_PATH=/mcp
PUBLIC_BASE_URL=http://localhost:8787

# mock keeps local MCP Inspector testing explicit with a bearer token.
# demo allows no-token ChatGPT testing with staging-safe adapters.
# broker enables OAuth login backed by Medusa customer auth.
# Use jwt when an external OAuth/OIDC provider exists.
AUTH_MODE=mock
MOCK_BEARER_TOKEN=dev-token
OAUTH_ISSUER=https://auth.yourcompany.example
OAUTH_AUDIENCE=https://mcp.yourcompany.example
OAUTH_JWKS_URL=https://auth.yourcompany.example/.well-known/jwks.json

SHOP_ADAPTER=mock

MEDUSA_BASE_URL=
MEDUSA_PUBLISHABLE_KEY=
MEDUSA_CUSTOMER_EMAIL=
MEDUSA_CUSTOMER_PASSWORD=
MEDUSA_TOKEN_CACHE_MS=1200000

OAUTH_BROKER_CLIENT_ID=chatgpt
OAUTH_BROKER_REDIRECT_URIS=https://chatgpt.com/connector_platform_oauth_redirect
OAUTH_BROKER_CODE_TTL_SEC=600
OAUTH_BROKER_ACCESS_TOKEN_TTL_SEC=3600
OAUTH_BROKER_REFRESH_TOKEN_TTL_SEC=2592000
OAUTH_BROKER_STORAGE_NAMESPACE=ai-app

# Brute-force protection on /oauth/login (the endpoint that proxies Medusa
# passwords). Counts attempts per source IP and per target email within the
# window. Set a limit to 0 to disable that dimension.
OAUTH_BROKER_LOGIN_RATE_LIMIT_IP=20
OAUTH_BROKER_LOGIN_RATE_LIMIT_EMAIL=10
OAUTH_BROKER_LOGIN_RATE_LIMIT_WINDOW_SEC=900

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional OpenObserve ingestion. Set full ingest URL, for example:
# https://openobserve.example.com/api/default/mcp_logs/_json
OPENOBSERVE_INGEST_URL=
OPENOBSERVE_AUTH_HEADER=

SERVICE_NAME=webshop-chatgpt-mcp
SERVICE_ENV=local
LOG_HASH_SALT=
