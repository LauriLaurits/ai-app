PORT=8787
MCP_PATH=/mcp
PUBLIC_BASE_URL=http://localhost:8787

# mock keeps local MCP Inspector testing explicit with a bearer token.
# demo allows no-token ChatGPT testing, but only with SHOP_ADAPTER=mock.
# Use jwt with real webshop data.
AUTH_MODE=mock
MOCK_BEARER_TOKEN=dev-token
OAUTH_ISSUER=https://auth.yourcompany.example
OAUTH_AUDIENCE=https://mcp.yourcompany.example
OAUTH_JWKS_URL=https://auth.yourcompany.example/.well-known/jwks.json

SHOP_ADAPTER=mock

# Optional OpenObserve ingestion. Set full ingest URL, for example:
# https://openobserve.example.com/api/default/mcp_logs/_json
OPENOBSERVE_INGEST_URL=
OPENOBSERVE_AUTH_HEADER=

SERVICE_NAME=webshop-chatgpt-mcp
SERVICE_ENV=local
LOG_HASH_SALT=
